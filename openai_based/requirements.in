# voice_ai_practices 의존성 정의
#
# 사용:
#   conda env (Python>=3.10) 활성화 후:
#     export VIRTUAL_ENV="$CONDA_PREFIX"
#     uv pip compile requirements.in -o requirements.txt --python-version 3.10
#     uv pip sync requirements.txt
#   또는 잠금 없이 한 번에:
#     uv pip install -r requirements.in

# OpenAI / Azure OpenAI SDK (Realtime beta API 포함)
# NOTE: TTS 의 `instructions` 파라미터(발화 스타일 자연어 제어)는 1.70.0 부터 지원.
openai==1.78.0

# .env 로딩
python-dotenv==1.0.1

