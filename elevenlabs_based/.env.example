# ElevenLabs API key — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# create_agent.py 가 자동 채워줍니다. 수동으로 대시보드에서 만든 경우 직접 입력하세요.
ELEVENLABS_AGENT_ID=

# (선택) 한국어 발화 voice_id 오버라이드. 비워두면 Rachel(다국어 기본) 사용.
